PORT=3000
NODE_ENV=development

# Supabase Pooler URL
DATABASE_URL=postgresql://postgres.project_ref:YOUR_PASSWORD@YOUR_POOLER_HOST:5432/postgres

# Optional: fallback to direct connection
DATABASE_URL_DIRECT=
# Exemplo:
# DATABASE_URL_DIRECT=postgresql://postgres:YOUR_PASSWORD@db.project_ref.supabase.co:5432/postgres

DB_SSL=true
DB_CONNECT_TIMEOUT_MS=10000

WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id
GROQ_API_KEY=your_groq_api_key
ADMIN_TOKEN=your_admin_token
PIX_KEY=your_pix_key
PENDING_ORDER_TTL_MINUTES=120
